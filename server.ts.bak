import express from "express";
import { createServer as createViteServer } from "vite";
import path from "path";
import { fileURLToPath } from "url";

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

async function startServer() {
  const app = express();
  const PORT = 3000;

  app.use(express.json());

  // In-memory idempotency store for MVP
  const idempotencyStore = new Set<string>();

  // Service Boundary: POST /api/bookings
  // This simulates the single approved service path.
  app.post("/api/bookings", async (req, res) => {
    const payload = req.body;
    const { idempotency_key } = payload;

    // 1. Idempotency Check
    if (idempotencyStore.has(idempotency_key)) {
      return res.status(409).json({
        error: "Conflict",
        message: "Duplicate request detected via idempotency_key",
        idempotency_key,
      });
    }

    // 2. Server-side Contract Validation
    const requiredFields = [
      "job_number",
      "customer_id",
      "oa_channel",
      "status",
      "slot_date",
      "slot_time",
      "area_key",
      "idempotency_key",
    ];

    for (const field of requiredFields) {
      if (!payload[field]) {
        return res.status(400).json({
          error: "Bad Request",
          message: `Missing required field: ${field}`,
        });
      }
    }

    // Strict enforcement: status must be 'confirmed'
    if (payload.status !== "confirmed") {
      return res.status(400).json({
        error: "Bad Request",
        message: "Status must be 'confirmed'",
      });
    }

    // Strict enforcement: no tech assignment allowed in this flow
    if (payload.assigned_tech_line_id) {
      return res.status(400).json({
        error: "Bad Request",
        message: "Direct technician assignment is prohibited in this intake flow",
      });
    }

    // 3. Simulate Database Write
    console.log("Writing to public.bookings:", payload);
    
    // Simulate network latency
    await new Promise((resolve) => setTimeout(resolve, 1200));

    // Simulate random "Unknown Commit State" (5% chance)
    if (Math.random() < 0.05) {
       return res.status(504).json({
         error: "Gateway Timeout",
         message: "The server did not respond in time. The commit state is unknown.",
       });
    }

    idempotencyStore.add(idempotency_key);

    return res.status(201).json({
      status: "success",
      id: crypto.randomUUID(),
      job_number: payload.job_number,
      message: "Booking successfully queued in public.bookings",
    });
  });

  // Vite middleware for development
  if (process.env.NODE_ENV !== "production") {
    const vite = await createViteServer({
      server: { middlewareMode: true },
      appType: "spa",
    });
    app.use(vite.middlewares);
  } else {
    const distPath = path.join(process.cwd(), "dist");
    app.use(express.static(distPath));
    app.get("*", (req, res) => {
      res.sendFile(path.join(distPath, "index.html"));
    });
  }

  app.listen(PORT, "0.0.0.0", () => {
    console.log(`Server running on http://localhost:${PORT}`);
  });
}

startServer();
